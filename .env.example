# Copy this file to ".env" for LOCAL testing, then fill in real values.
# (On GitHub, you set these as repository Secrets instead — see README.)
#
# Load locally with:   set -a && source .env && set +a

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# The Gmail account that SENDS the newsletter
GMAIL_ADDRESS=youraddress@gmail.com

# A Gmail "App Password" (NOT your normal password). See README for how to create.
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Where to deliver. Can be the same as GMAIL_ADDRESS, or any other inbox.
RECIPIENT_EMAIL=youraddress@gmail.com

# ── optional ──────────────────────────────────────────────────────────
# Higher-quality (slower, pricier) model:
# NEWSLETTER_MODEL=claude-opus-4-8
# Test without actually sending (renders last_issue.html only):
# DRY_RUN=1
